                        <i class="far fa-envelope"></i>
                    </a>
                </div>
                <form name="contacto" netlify action="/success">
                    <input type="text" name="nombre" placeholder="Nombre completo" required>
                    <input type="email" name="email" placeholder="Correo electrónico" required>
                    <input type="tel" name="telefono" placeholder="Teléfono (opcional)">
                    <select name="servicio" required aria-labelledby="state">
                        <option value="" disabled selected>Selecciona un servicio</option>
                        <option value="levantamientos">Levantamientos de Inmueble</option>
                        <option value="calculos">Cálculos Estructurales</option>
                        <option value="licencias">Gestiones para Licencias</option>
                        <option value="otros">Otros servicios</option>
                    </select>
                    <textarea name="mensaje" rows="5" placeholder="Describe tu proyecto o consulta..." required></textarea>
                    
                    <button type="submit" class="submit-btn" id="submit-btn">
                        <span class="submit-btn-text">Enviar mensaje</span>
