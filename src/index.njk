<script>
document.addEventListener('DOMContentLoaded', () => {
  // Hero reveal
  requestAnimationFrame(() => {
    document.querySelector('.hero-content')?.classList.add('show');
  });

  // Cuando el video esté disponible: descomentar el <video> en el HTML
  // y este bloque se encargará de mostrarlo suavemente al cargar
  const video = document.querySelector('.hero-video');
  const grid  = document.getElementById('hero-grid');
  if (video) {
    video.addEventListener('canplay', () => {
      video.classList.add('loaded');
      grid?.classList.add('hidden'); // oculta la cuadrícula cuando carga el video
    }, { once: true });
  }

  // Scroll reveal de secciones
  const observer = new IntersectionObserver((entries) => {
    requestAnimationFrame(() => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('show');
          observer.unobserve(entry.target);
        }
      });
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.section').forEach(s => observer.observe(s));
});
</script>
