<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Sistemas TVO | Seguridad Electrónica CDMX") }}</title>
  <meta name="description" content="{{ description | default('Instalación y mantenimiento de sistemas de seguridad electrónica en CDMX y Área Metropolitana. 20 años de experiencia.') }}">

  <link rel="canonical" href="{{ site.url }}{{ page.url | replace('/index.html', '/') }}" />

  <link rel="icon" type="image/png" href="/img/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
  <link rel="shortcut icon" href="/img/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Sistemas TVO" />
  <link rel="manifest" href="/img/site.webmanifest" />

  <link rel="preconnect" href="https://images.dmca.com" crossorigin>

  <!-- Fuentes locales -->
  <link rel="stylesheet" href="{{ site.css.fonts | url }}">

  <!-- Estilos principales (carga diferida para performance) -->
  <link rel="stylesheet" href="{{ site.css.main | url }}" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ site.css.main | url }}"></noscript>
  {% if site.css.critical %}
    <link rel="stylesheet" href="{{ site.css.critical | url }}">
  {% endif %}

  <link rel="preload" href="/img/logo.webp" as="image" imagesrcset="/img/logo.webp" imagesizes="100vw">

  {% if metaTags %}
    {{ metaTags | safe }}
  {% endif %}

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-NC6XELGW6F"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-NC6XELGW6F');
  </script>

</head>
<body>
  {% include "header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  {% for script in site.scripts %}
    <script src="{{ script.src }}" {% if script.defer %}defer{% endif %}></script>
  {% endfor %}

  {% if pageScripts %}
    {{ pageScripts | safe }}
  {% endif %}
</body>
</html>
