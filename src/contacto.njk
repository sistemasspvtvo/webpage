    <style>
      .contact-wrap {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 60px 40px 80px;
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 60px;
        align-items: start;
      }

      /* ---- Info lateral ---- */
      .contact-info { position: sticky; top: 80px; }

      .contact-info .section-sub {
        margin-bottom: 40px;
        max-width: 100%;
      }

      .contact-channel {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 0;
        border-bottom: 1px solid var(--border-subtle);
        text-decoration: none;
        transition: gap 0.2s;
      }
      .contact-channel:hover { gap: 22px; }
      .contact-channel:last-child { border-bottom: none; }

      .channel-icon {
        width: 42px; height: 42px;
        background: var(--yellow-dim);
        border: 1px solid var(--border-yellow);
        border-radius: var(--border-radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .channel-icon svg { width: 20px; height: 20px; }

      .channel-label {
        font-family: var(--font-display);
        font-size: 0.7rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-muted);
        display: block;
        margin-bottom: 3px;
      }
      .channel-value {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      /* ---- Formulario ---- */
      .contact-form-wrap {
        background: var(--dark-2);
        border: 1px solid var(--border-subtle);
        padding: 40px;
      }

      .contact-form-wrap h2 {
        font-size: 1.6rem;
        margin: 0 0 6px;
        color: var(--text-light);
      }

      .contact-form-wrap .form-sub {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin: 0 0 30px;
        font-weight: 300;
      }

      form { display: grid; gap: 16px; }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      input, textarea, select {
        width: 100%;
        padding: 12px 16px;
        background: var(--dark-3);
        border: 1px solid var(--border-subtle);
        border-radius: var(--border-radius-sm);
        color: var(--text-light);
        font-family: var(--font-body);
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
        -webkit-appearance: none;
      }

      input::placeholder,
      textarea::placeholder { color: var(--text-muted); }

      select { color: var(--text-muted); cursor: pointer; }
      select option { background: var(--dark-3); color: var(--text-light); }

      input:focus, textarea:focus, select:focus {
        outline: none;
        border-color: var(--yellow);
        box-shadow: 0 0 0 3px var(--yellow-dim);
        color: var(--text-light);
      }

      input:valid:not(:placeholder-shown),
      textarea:valid:not(:placeholder-shown) {
        border-left: 3px solid #4CAF50;
      }

      input:invalid:not(:placeholder-shown),
      textarea:invalid:not(:placeholder-shown) {
        border-left: 3px solid #f44336;
      }

      textarea { resize: vertical; min-height: 130px; }

      .submit-btn {
        background: var(--yellow);
        color: var(--dark);
        border: none;
        padding: 14px 32px;
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        border-radius: var(--border-radius-sm);
        cursor: pointer;
        position: relative;
        transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
        width: 100%;
      }
      .submit-btn:hover {
        background: #fff;
        box-shadow: 0 0 24px var(--yellow-glow);
        transform: translateY(-2px);
      }
      .submit-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
      }

      .submit-btn-text { transition: opacity 0.2s; }
      .submit-btn-text.hidden { opacity: 0; }

      .spinner {
        position: absolute;
        left: 50%; top: 50%;
        transform: translate(-50%, -50%);
        opacity: 0;
        transition: opacity 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
      }
      .spinner.active { opacity: 1; }

      /* Spinner SVG animation */
      .spin { animation: rotating 0.8s linear infinite; }
      @keyframes rotating {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }

      .form-note {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-align: center;
        margin-top: 4px;
      }

      /* ---- Responsive ---- */
      @media (max-width: 860px) {
        .contact-wrap {
          grid-template-columns: 1fr;
          padding: 40px 20px 60px;
          gap: 40px;
        }
        .contact-info { position: static; }
        .contact-form-wrap { padding: 28px 20px; }
        .form-row { grid-template-columns: 1fr; }
      }
    </style>
