    <style>
      /* ===== HERO ===== */
      .hero-wrap {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: var(--dark);
      }

      /* Video de fondo */
      .hero-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        opacity: 0;
        transition: opacity 1.2s ease;
      }
      .hero-video.loaded { opacity: 0.22; }

      /* Fallback mientras no hay video: cuadrícula animada */
      .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(250,243,32,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(250,243,32,0.05) 1px, transparent 1px);
        background-size: 60px 60px;
        animation: gridMove 20s linear infinite;
        z-index: 0;
        transition: opacity 1s ease;
      }
      .hero-grid.hidden { opacity: 0; }
      @keyframes gridMove {
        from { background-position: 0 0; }
        to   { background-position: 60px 60px; }
      }

      /* Overlay oscuro sobre el video */
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(13,27,42,0.82) 0%,
          rgba(13,27,42,0.55) 60%,
          rgba(13,27,42,0.75) 100%
