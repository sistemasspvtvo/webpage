        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-bottom: 36px;
      }
      .notifier-features li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.6;
      }
      .notifier-features li::before {
        content: '▶';
        color: var(--yellow);
        font-size: 0.6rem;
        margin-top: 5px;
        flex-shrink: 0;
      }
      .cert-badge {
        display: inline-flex;
