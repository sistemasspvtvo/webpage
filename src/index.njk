<style>
  /* ===== VARIABLES ===== */
  :root {
    --dark:       #0D1B2A;
    --dark-2:     #112236;
    --dark-3:     #152A42;
    --yellow:     #FAF320;
    --yellow-dim: rgba(250, 243, 32, 0.15);
    --yellow-glow:rgba(250, 243, 32, 0.35);
    --gray-light: #E8E8E8;
    --text-light: #F0F0F0;
    --text-muted: #9EAFC2;
    --font-display: 'Barlow Condensed', sans-serif;
    --font-body:    'Barlow', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--dark);
    color: var(--text-light);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
  }

  /* ===== HERO ===== */
  .hero-wrap {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--dark);
  }

  /* Animated grid background */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(250,243,32,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(250,243,32,0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridMove 20s linear infinite;
    z-index: 0;
  }
  @keyframes gridMove {
    0%   { background-position: 0 0; }
    100% { background-position: 60px 60px; }
  }

  /* Radial glow behind headline */
  .hero-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(250,243,32,0.08) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    animation: pulse 4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: translate(-50%,-50%) scale(1); }
    50%       { opacity: 1;   transform: translate(-50%,-50%) scale(1.08); }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 40px 80px;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
  .hero-content.show {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--yellow-dim);
    border: 1px solid var(--yellow);
    border-radius: 2px;
    padding: 6px 14px;
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 28px;
  }
  .hero-badge::before {
    content: '';
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--yellow);
    border-radius: 50%;
    animation: blink 1.5s ease-in-out infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6.5rem);
    font-weight: 800;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 28px;
  }
  .hero h1 span {
    color: var(--yellow);
    display: block;
  }

  .hero p {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    font-weight: 300;
    color: var(--text-muted);
    max-width: 580px;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--yellow);
    color: var(--dark);
    padding: 14px 34px;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover {
    background: #fff;
    box-shadow: 0 0 24px var(--yellow-glow);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-light);
    padding: 14px 34px;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(240,240,240,0.3);
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-secondary:hover {
    border-color: var(--yellow);
    color: var(--yellow);
    transform: translateY(-2px);
  }

  /* Stats strip */
  .stats-strip {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    margin-top: 70px;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 40px;
    gap: 0;
  }
  .stat-item {
    flex: 1 1 150px;
    padding: 10px 20px 10px 0;
  }
  .stat-item:not(:last-child) {
    border-right: 1px solid rgba(255,255,255,0.08);
    margin-right: 20px;
  }
  .stat-number {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 800;
    color: var(--yellow);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-top: 4px;
  }

  /* ===== SECTION BASE ===== */
  .section {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .section.show {
    opacity: 1;
    transform: translateY(0);
  }

  .section-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 12px;
    display: block;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-light);
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.7;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ===== SERVICIOS ===== */
  .services-section {
    padding: 100px 0;
    background: var(--dark-2);
  }

  .services-header {
    text-align: left;
    margin-bottom: 60px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px;
  }

  .service-card {
    background: var(--dark-3);
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
    border-bottom: 3px solid transparent;
    cursor: default;
  }
  .service-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 3px;
    background: var(--yellow);
    transition: width 0.4s ease;
  }
  .service-card:hover::before { width: 100%; }
  .service-card:hover { background: #1a2f47; }

  .service-card:hover .service-icon { color: var(--yellow); }

  .service-icon {
    width: 40px;
    height: 40px;
    color: var(--text-muted);
    margin-bottom: 20px;
    transition: color 0.3s;
  }

  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 12px;
  }

  .service-card p {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .service-link {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--yellow);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.2s;
  }
  .service-link:hover { gap: 12px; }

  /* ===== NOTIFIER BANNER ===== */
  .notifier-section {
    padding: 90px 0;
    background: var(--dark);
    position: relative;
    overflow: hidden;
  }
  .notifier-section::before {
    content: 'NOTIFIER';
    position: absolute;
    font-family: var(--font-display);
    font-size: 18vw;
    font-weight: 800;
    color: rgba(250,243,32,0.03);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
    z-index: 0;
  }

  .notifier-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .notifier-text .section-sub {
    max-width: 100%;
    margin-bottom: 30px;
  }

  .notifier-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 36px;
  }
  .notifier-features li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .notifier-features li::before {
    content: '▶';
    color: var(--yellow);
    font-size: 0.6rem;
    margin-top: 5px;
    flex-shrink: 0;
  }

  .cert-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--yellow-dim);
    border: 1px solid var(--yellow);
    border-radius: 2px;
    padding: 14px 20px;
    margin-bottom: 28px;
  }
  .cert-badge-icon {
    width: 32px; height: 32px;
    color: var(--yellow);
    flex-shrink: 0;
  }
  .cert-badge-text {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--yellow);
    line-height: 1.4;
  }
  .cert-badge-text strong { display: block; font-size: 1rem; }

  .notifier-visual {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 24px;
    background: var(--dark-3);
    border-left: 3px solid transparent;
    transition: border-color 0.2s, background 0.2s;
  }
  .spec-row:hover {
    border-left-color: var(--yellow);
    background: var(--dark-2);
  }
  .spec-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text-light);
    letter-spacing: 0.5px;
  }
  .spec-value {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: right;
    max-width: 200px;
  }

  /* ===== POR QUÉ NOSOTROS ===== */
  .why-section {
    padding: 100px 0;
    background: var(--yellow);
    position: relative;
    overflow: hidden;
  }
  .why-section::after {
    content: '20';
    position: absolute;
    font-family: var(--font-display);
    font-size: 50vw;
    font-weight: 800;
    color: rgba(0,0,0,0.04);
    top: -10%;
    right: -10%;
    line-height: 1;
    pointer-events: none;
  }

  .why-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
    align-items: start;
  }

  .why-left .section-label { color: rgba(0,0,0,0.5); }
  .why-left .section-title { color: var(--dark); }
  .why-left .section-sub   { color: rgba(13,27,42,0.7); }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .why-card {
    background: var(--dark);
    padding: 32px 28px;
    transition: background 0.2s;
  }
  .why-card:hover { background: var(--dark-2); }

  .why-num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    color: var(--yellow);
    line-height: 1;
    margin-bottom: 12px;
  }

  .why-card h4 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }

  .why-card p {
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ===== CTA FINAL ===== */
  .cta-section {
    padding: 120px 0;
    background: var(--dark-2);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(250,243,32,0.06) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .cta-inner .section-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    margin-bottom: 20px;
  }

  .cta-inner .section-sub {
    max-width: 100%;
    margin: 0 auto 40px;
    text-align: center;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .notifier-inner,
    .why-inner { grid-template-columns: 1fr; gap: 40px; }
    .why-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .container { padding: 0 20px; }
    .hero-content { padding: 80px 20px; }
    .stats-strip { gap: 20px; }
    .stat-item:not(:last-child) { border-right: none; margin-right: 0; }
    .why-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation: none !important; transition: none !important; }
    .hero-content, .section { opacity: 1 !important; transform: none !important; }
  }
</style>
</head>

<!-- ===== HERO ===== -->
